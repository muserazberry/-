# 국가법령정보센터 OPEN API 인증값 (신청 시 등록한 이메일의 ID 부분)
# 예) 이메일이 hong@korea.kr 이면 LAW_OC=hong
LAW_OC=test

# 열린국회정보 OPEN API 인증키
ASSEMBLY_KEY=

# 열린국회정보 의안 서비스 ID (기본: 국회의원 발의법률안)
# 본인 대시보드에서 구독한 서비스 ID로 바꿀 수 있습니다.
ASSEMBLY_BILL_SERVICE=TVBPMBILL11

# 분석 대상 국회 대수 (22대 = 2024~2028)
ASSEMBLY_AGE=22

# 국회도서관 세미나 일정 서비스 ID (seminar 출처, ASSEMBLY_KEY 재사용).
# 열린국회정보 대시보드에서 구독한 '세미나 일정' 서비스 ID를 입력하세요.
# 비워 두면 seminar 출처는 안내 메시지를 반환합니다.
ASSEMBLY_SEMINAR_SERVICE=
ASSEMBLY_SEMINAR_LIMIT=60

# 법령 → 연계 자치법규 목록 조회 서비스 target (법제처 공식 매핑)
# 기본 lnkLs. 연계 분석을 끄려면 비워 두세요.
LAW_LINK_TARGET=lnkLs

# 정부입법지원센터 입법예고(통과 전, 선제 대응용) 인증 OC.
# 법제처 동일 계정이므로 비워 두면 LAW_OC 를 그대로 사용합니다.
LAWMAKING_OC=
LAWMAKING_LIMIT=100

# 경기도 예산·업무보고 (budget 출처): 세출예산 CSV 경로.
# 경기도청/교육청 예산서(엑셀)를 CSV로 저장하거나 경기데이터드림 CSV를 넣으세요.
# 컬럼명(사업명/부서/본예산/전년도예산 등)은 자동 인식합니다.
BUDGET_FILE=
BUDGET_TOP_N=30           # 금액 상위 N개를 '대규모'로 표시
BUDGET_INCREASE_PCT=0.5   # 전년 대비 +50% 이상이면 '증액'
BUDGET_ONLY_FLAGGED=true  # 신규·대규모·증액 사업만 추림 (false면 전체)

# 경기도의회 입법예고(조례안) 수집 건수 상한. RSS·API가 없어 게시판 HTML을
# 직접 파싱하므로 인증키는 필요 없습니다(사이트 구조가 바뀌면 파서 조정 필요).
COUNCIL_LIMIT=100

# 국민신문고 민원 질의응답 / 국민생각함 국민제안 (전국 단위 게시판, HTML 파싱).
# 인증키 불필요. 전체 수집 후 소관기관을 메타 태그로 표시하며, 제목↔조례명
# 매칭이 부정확해 '참고용'으로만 노출됩니다(미반영·추천 건수에서 제외).
EPEOPLE_LIMIT=60

# 정책/보도자료 RSS 피드 (쉼표 구분) — 단계 ④⑤ 신호 출처
# 정부 정책브리핑·경기도 등. 실제 피드 URL은 각 사이트에서 확인 후 입력하세요.
# 예) POLICY_FEEDS=https://www.korea.kr/rss/policy.xml,https://www.gg.go.kr/rss/news.xml
POLICY_FEEDS=
RSS_ITEM_LIMIT=40
